-- ===== Scoped task registry =====
local function Scope()
    local tasks = {}
    return {
        Add = function(item)
            tasks[#tasks + 1] = item
            return item
        end,
        Clean = function()
            for i = #tasks, 1, -1 do
                local item = tasks[i]
                if typeof(item) == "RBXScriptConnection" then item:Disconnect()
                elseif typeof(item) == "Instance" then item:Destroy()
                elseif type(item) == "function" then item() end
            end
            table.clear(tasks)
        end,
    }
end

