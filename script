        function TabObj:AddHeader(text)
            local header = Create("TextLabel", page, { Text = text, Size = UDim2.new(1, 0, 0, 24), BackgroundTransparency = 1, TextColor3 = Theme.Accent, Font = Enum.Font.GothamBlack, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left })
            Decorate(header, nil, nil, {10, nil, 15, nil})
            return header
        end

        function TabObj:AddToggle(props)
            local state = props.Default or false
            local frame, stroke = CreateRow(page, state)
            local toggleBtn = CreateRowTitle(frame, props.Name)
            toggleBtn.Size = UDim2.new(1, 0, 1, 0)

            local loopEntry
            if props.Loop then
                loopEntry = Library:RegisterLoop(props.Loop.Type or "RenderStepped", props.Loop.Func, nil, props.Loop.Interval)
                loopEntry.Active = state
            end

            local function ApplyVisual(animated)
                local fc = state and Theme.ToggleActive or Theme.Section
                local sc = state and Theme.Active or Theme.Stroke
                if animated then
                    Tween(frame, {BackgroundColor3 = fc})
                    Tween(stroke, {Color = sc, Transparency = state and 0.2 or 0.7})
                else
                    frame.BackgroundColor3, stroke.Color = fc, sc
                end
            end
            local function SetState(newState)
                if state == newState then return end
                state = newState
                if loopEntry then loopEntry.Active = state end
                ApplyVisual(true)
                if props.Callback then props.Callback(state) end
            end
            ApplyVisual(false)
            if state and props.Callback then props.Callback(state) end  -- apply if starting enabled
            if props.ResetOnRespawn then table.insert(ResetOnRespawn, function() SetState(props.Default or false) end) end
            toggleBtn.MouseButton1Click:Connect(function() SetState(not state) end)
            if props.Keybind then CreateBindButton(frame, props, function() SetState(not state) end) end
            return { SetState = SetState, Get = function() return state end, Loop = loopEntry, Instance = frame }
        end

        function TabObj:AddKeybind(props)
