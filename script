-- bring / goto / return
local BRING_OFFSET = CFrame.new(0, 0, -6) -- hold the target ~6 studs in front of you
local returnCF, heldTarget, victimOrigCF = nil, nil, nil
local function StopBring() heldTarget, victimOrigCF = nil, nil end
local function ApplyBring()
    local tChar = heldTarget and heldTarget.Character
    local tHRP = tChar and tChar:FindFirstChild("HumanoidRootPart")
    local hum = tChar and tChar:FindFirstChildOfClass("Humanoid")
    local down = tChar and (tChar:GetAttribute("Downed") or tChar:GetAttribute("Dead"))
    if not (tHRP and hum) or hum.Health <= 0 or down then
        if tHRP and victimOrigCF then tHRP.CFrame = victimOrigCF end -- Down/Dead: snap the body back to where we grabbed them
        StopBring()
        return
    end
    local _, _, myHRP = GetHum()
    if myHRP then tHRP.CFrame = myHRP.CFrame * BRING_OFFSET end
end
local function Bring(target)
    local p = ResolvePlayer(target)
    if p and p.Character then
        heldTarget = p
        local tHRP = p.Character:FindFirstChild("HumanoidRootPart")
        victimOrigCF = tHRP and tHRP.CFrame or nil -- remember their spot so we can return them on Down/Dead
    end
end
-- when the goto target goes Downed/Dead, auto-return YOU to your pre-Goto spot
local gotoWatch = Scope()
Root.Add(gotoWatch.Clean)
local function ReturnSelf()
    local myChar = LocalPlayer.Character
    if myChar and returnCF then myChar:PivotTo(returnCF); returnCF = nil end
end
local function WatchGotoTarget(p)
    gotoWatch.Clean()
    local char = p and p.Character
    if not char then return end
    local function onState()
        if not (char:GetAttribute("Downed") or char:GetAttribute("Dead")) then return end
        gotoWatch.Clean()
        ReturnSelf()
    end
    gotoWatch.Add(char:GetAttributeChangedSignal("Downed"):Connect(onState))
    gotoWatch.Add(char:GetAttributeChangedSignal("Dead"):Connect(onState))
    onState() -- in case they're already down when we arrive
end
local function GotoPlayer(target)
    local p = ResolvePlayer(target); if not (p and p.Character) then return end
    local char, _, hrp = GetHum()
    local tHRP = p.Character:FindFirstChild("HumanoidRootPart")
    if char and hrp and tHRP then
        if not returnCF then returnCF = hrp.CFrame end
        char:PivotTo(tHRP.CFrame * CFrame.new(0, 0, 3))
        WatchGotoTarget(p)
    end
end
local function ReturnBack()
    gotoWatch.Clean()
    if heldTarget and victimOrigCF then -- if we were bringing someone, put them back where we grabbed them
        local tHRP = heldTarget.Character and heldTarget.Character:FindFirstChild("HumanoidRootPart")
        if tHRP then tHRP.CFrame = victimOrigCF end
    end
    ReturnSelf()
    StopBring()
end
