Library:RegisterTab("Teleport", function(tab)
    tab:AddHeader("CLICK TP")
    tab:AddToggle({ Name = "Ctrl + Click TP", Keybind = "NONE", Default = false, Callback = function(state) Mafia.CtrlClickTP.Enabled = state end })

    tab:AddHeader("TARGET")
    local targetMap = {}
    local function TargetName(p) local c = p.Character return (c and c.Name) or p.DisplayName or p.Name end -- disguise name
    local targetDD = tab:AddDropdown({ Name = "Player", Populate = function()
        table.clear(targetMap)
        local names = {}
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then
                local c = p.Character
                local hum = c and c:FindFirstChildOfClass("Humanoid")
                local dead = (c and c:GetAttribute("Dead") == true) or (hum and hum.Health <= 0) or not c
                if not dead then -- skip dead players (their disguise leaves the list)
                    local nm = TargetName(p)
                    names[#names + 1] = nm
                    targetMap[nm] = p
                end
            end
        end
        if #names == 0 then names[1] = "(none)" end
        return names
    end })
    local function Target() return targetMap[targetDD.Get()] end
    tab:AddButton({ Name = "Teleport to", Callback = function() GotoPlayer(Target()) end })
    tab:AddButton({ Name = "Bring to you", Callback = function() Bring(Target()) end })
    -- Reset undoes either action: returns you (and any bring victim) and releases the bring
    tab:AddButton({ Name = "Reset", Callback = function() ReturnBack() end })
end)

