        function TabObj:AddDropdown(props)
            local wrapper = CreateRow(page, false)
            wrapper.AutomaticSize, wrapper.ClipsDescendants, wrapper.ZIndex = Enum.AutomaticSize.Y, false, 1
            Create("UIListLayout", wrapper, { SortOrder = Enum.SortOrder.LayoutOrder })

            local current = tostring(props.Default or (props.Options and props.Options[1]) or "")
            local header = Create("TextButton", wrapper, TITLE_PROPS)
            header.Text, header.Size, header.ZIndex = props.Name .. ": " .. current, UDim2.new(1, 0, 0, 45), 2
            Decorate(header, nil, nil, {nil, nil, 15, nil})

            local icon = Create("TextLabel", header, { Text = "+", Size = UDim2.new(0, 30, 1, 0), Position = UDim2.new(1, -30, 0, 0), BackgroundTransparency = 1, TextColor3 = Theme.SubText, Font = Enum.Font.GothamBold, TextSize = 18, ZIndex = 2 })
            local DROPDOWN_MAX = 175 -- cap the open list height; longer lists scroll inside instead of ballooning the tab
            local optionFrame = Create("ScrollingFrame", wrapper, { Size = UDim2.new(1, 0, 0, 0), BackgroundTransparency = 1, LayoutOrder = 1, Visible = false, ZIndex = 3, BorderSizePixel = 0, ScrollBarThickness = 3, ScrollBarImageColor3 = Theme.Accent, ScrollingDirection = Enum.ScrollingDirection.Y, CanvasSize = UDim2.new(0, 0, 0, 0), AutomaticCanvasSize = Enum.AutomaticSize.Y })
            local optLayout = Create("UIListLayout", optionFrame, { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 5) })
            Decorate(optionFrame, nil, nil, {nil, 8, 8, 8})
            optLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                optionFrame.Size = UDim2.new(1, 0, 0, math.min(optLayout.AbsoluteContentSize.Y + 10, DROPDOWN_MAX))
            end)

            local function Close() optionFrame.Visible, icon.Text, wrapper.ZIndex = false, "+", 1 end
            local function Select(opt, fire)
                current = opt
                header.Text = props.Name .. ": " .. opt
                Close()
                if fire and props.Callback then props.Callback(opt) end
            end
            local function Rebuild(options)
                for _, c in ipairs(optionFrame:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
                for _, opt in ipairs(options) do
                    local optBtn = Create("TextButton", optionFrame, { Text = opt, Size = UDim2.new(1, 0, 0, 35), BackgroundColor3 = Theme.DropdownOption, BackgroundTransparency = 0.1, TextColor3 = Theme.SubText, Font = Enum.Font.Gotham, TextSize = 13, AutoButtonColor = false, ZIndex = 4 })
                    Decorate(optBtn, UI_CORNER_6)
                    Hover(optBtn, {BackgroundTransparency = 0, TextColor3 = Theme.Text}, {BackgroundTransparency = 0.1, TextColor3 = Theme.SubText})
                    optBtn.MouseButton1Click:Connect(function() Select(opt, true) end)
                end
            end
            local function Refresh() Rebuild(props.Populate and props.Populate() or props.Options or {}) end
            Refresh()

            DropdownClosers[wrapper] = Close
            wrapper.Destroying:Connect(function() DropdownClosers[wrapper] = nil end)
            header.MouseButton1Click:Connect(function()
                local opening = not optionFrame.Visible
                for _, close in pairs(DropdownClosers) do close() end
                if opening then
                    if props.Populate then Refresh() task.wait() end
                    if wrapper.Parent then
                        optionFrame.Visible, icon.Text, wrapper.ZIndex = true, "-", 100
                        local cp = page.CanvasPosition -- nudge scroll so the tab repaints the newly-shown rows (fixes stale layout)
                        page.CanvasPosition = cp + Vector2.new(0, 1)
                        page.CanvasPosition = cp
                    end
                end
            end)
            return { Set = function(o) Select(o, true) end, Get = function() return current end, Refresh = Refresh, Instance = wrapper }
        end

        function TabObj:AddSlider(props)
            local min, max = props.Min or 0, props.Max or 100
            local span = max - min
            if span == 0 then span = 1 end
            local decimals = props.Int and 0 or (props.Decimals or 2)
            local fmtStr = "%." .. tostring(decimals) .. "f"
            local function Round(v)
                v = math.clamp(v, min, max)
                local m = 10 ^ decimals
                return math.round(v * m) / m
            end
            local default = Round(props.Default or min)
            local frame = CreateRow(page, false)
            local title = Create("TextLabel", frame, TITLE_PROPS)
            title.Text, title.Size = props.Name, UDim2.new(0.5, 0, 0.5, 0)
            Decorate(title, nil, nil, {nil, nil, 15, nil})

            local valText = Create("TextLabel", frame, { Text = string.format(fmtStr, default), Size = UDim2.new(0.5, -30, 0.5, 0), Position = UDim2.new(0.5, 0, 0, 0), BackgroundTransparency = 1, TextColor3 = Theme.SubText, Font = Enum.Font.Gotham, TextSize = 14, TextXAlignment = Enum.TextXAlignment.Right })
            local sliderBg = Create("Frame", frame, {Size = UDim2.new(1, -30, 0, 6), Position = UDim2.new(0, 15, 0.7, 0), BackgroundColor3 = Theme.SliderTrack, BorderSizePixel = 0})
            Decorate(sliderBg, UI_CORNER_6)
            local sliderFill = Create("Frame", sliderBg, {Size = UDim2.new((default - min) / span, 0, 1, 0), BackgroundColor3 = Theme.Accent, BorderSizePixel = 0})
            Decorate(sliderFill, UI_CORNER_6)

            local current = default
            local function ApplyValue(v, fire)
                v = Round(v)
                current = v
                valText.Text = string.format(fmtStr, v)
                Tween(sliderFill, {Size = UDim2.new((v - min) / span, 0, 1, 0)}, 0.1)
                if fire and props.Callback then props.Callback(v) end
                return v
            end
            local function SetFromInput(input)
                local pos = math.clamp((input.Position.X - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X, 0, 1)
                ApplyValue(min + pos * span, true)
            end
            sliderBg.InputBegan:Connect(function(input)
                if IsPress(input.UserInputType) then SetFromInput(input) BeginDrag(SetFromInput) end
            end)
            if props.ResetOnRespawn then table.insert(ResetOnRespawn, function() ApplyValue(default, true) end) end
            return { Set = function(v) return ApplyValue(v, true) end, Get = function() return current end, Instance = frame }
        end

        return TabObj
    end
    return WindowObj
end

