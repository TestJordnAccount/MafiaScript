local function UpdateESP()
    local camPos = CurrentCam().CFrame.Position
    for player, cache in pairs(espCache) do
        local char = player.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        local last = cache._last
        if root and hum and hum.Health > 0 then
            local side = mafiaSet[player.UserId]; local confirmed = confirmedMafia[player]; local sabo = (player == saboteur)
            local color = (side or confirmed) and RED_COLOR or (sabo and SABOTEUR_CHAMS) or Mafia.ESP.ChamsColor
            if last.color ~= color then
                cache.Chams.FillColor = color; cache.Chams.OutlineColor = color; cache.Name.TextColor3 = color; cache.Disguise.TextColor3 = color; last.color = color
            end
            if last.charAdornee ~= char then cache.Chams.Adornee = char; last.charAdornee = char end
            if cache.Chams.Enabled ~= Mafia.ESP.Chams then cache.Chams.Enabled = Mafia.ESP.Chams end
            local roleText = confirmed and "MAFIA" or (side and "EVIL SIDE") or (sabo and "SABOTEUR") or nil
            local roleOn = (Mafia.ESP.Roles and roleText) and true or false
            local billOn = roleOn or Mafia.ESP.Disguise or Mafia.ESP.Usernames or Mafia.ESP.Distance
            if last.rootAdornee ~= root then cache.Billboard.Adornee = root; last.rootAdornee = root end
            if cache.Billboard.Enabled ~= billOn then cache.Billboard.Enabled = billOn end
            if cache.Role.Visible ~= roleOn then cache.Role.Visible = roleOn end
            if roleOn then
                if last.roleText ~= roleText then cache.Role.Text = roleText; last.roleText = roleText end
                local rc = confirmed and RED_COLOR or (side and ORANGE_COLOR) or SABOTEUR_COLOR
                if last.roleColor ~= rc then cache.Role.TextColor3 = rc; last.roleColor = rc end
            end
            if cache.Disguise.Visible ~= Mafia.ESP.Disguise then cache.Disguise.Visible = Mafia.ESP.Disguise end
            if Mafia.ESP.Disguise and last.disguise ~= char.Name then cache.Disguise.Text = char.Name; last.disguise = char.Name end
            if cache.Name.Visible ~= Mafia.ESP.Usernames then cache.Name.Visible = Mafia.ESP.Usernames end
            if Mafia.ESP.Usernames then
                local nm = (player.DisplayName ~= "" and player.DisplayName) or player.Name
