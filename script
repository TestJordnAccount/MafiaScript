local function Tween(obj, props, time)
    if ActiveTweens[obj] then ActiveTweens[obj]:Cancel() end
    local t = TweenService:Create(obj, TweenInfo.new(time or DEFAULT_TWEEN_TIME, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), props)
    ActiveTweens[obj] = t
    t.Completed:Connect(function() if ActiveTweens[obj] == t then ActiveTweens[obj] = nil end end)
    t:Play()
    return t
end

local function Create(class, parent, props)
    local obj = Instance.new(class)
    for k, v in pairs(props) do obj[k] = v end
    if parent then obj.Parent = parent end
    return obj
end

local function Decorate(obj, corner, stroke, pad)
    if corner then Create("UICorner", obj, {CornerRadius = corner}) end
    local strokeObj
    if stroke then strokeObj = Create("UIStroke", obj, {Color = stroke[1], Transparency = stroke[2], Thickness = stroke[3] or 1}) end
    if pad then
        Create("UIPadding", obj, { PaddingTop = UDim.new(0, pad[1] or 0), PaddingBottom = UDim.new(0, pad[2] or 0), PaddingLeft = UDim.new(0, pad[3] or 0), PaddingRight = UDim.new(0, pad[4] or 0) })
    end
    return obj, strokeObj
end

local function Glass(obj)
    Create("UIGradient", obj, { Rotation = 90, Color = ColorSequence.new(Color3.fromRGB(225, 240, 255), Color3.fromRGB(140, 165, 205)), Transparency = NumberSequence.new(0, 0.12) })
    return obj
end

local function WireButton(btn, downProps, upProps, callback)
    btn.MouseButton1Down:Connect(function() Tween(btn, downProps) end)
    btn.MouseButton1Up:Connect(function() Tween(btn, upProps) end)
    btn.MouseLeave:Connect(function() Tween(btn, upProps) end)
    if callback then btn.MouseButton1Click:Connect(callback) end
    return btn
end

local function Hover(btn, over, out)
    btn.MouseEnter:Connect(function() Tween(btn, over, 0.15) end)
    btn.MouseLeave:Connect(function() Tween(btn, out, 0.15) end)
    return btn
end

local function IsPress(t) return t == Enum.UserInputType.MouseButton1 or t == Enum.UserInputType.Touch end
local function IsMove(t) return t == Enum.UserInputType.MouseMovement or t == Enum.UserInputType.Touch end

local dragScope = Scope()
Root.Add(dragScope.Clean)
local function BeginDrag(onMove)
    dragScope.Clean()
    dragScope.Add(UIS.InputChanged:Connect(function(i)
        if IsMove(i.UserInputType) then onMove(i) end
    end))
    dragScope.Add(UIS.InputEnded:Connect(function(i)
        if IsPress(i.UserInputType) then dragScope.Clean() end
    end))
end

local function MakeDraggable(handle, target)
    target = target or handle
    local dragStart, startPos, active
    handle.InputBegan:Connect(function(input)
        if not IsPress(input.UserInputType) then return end
        dragStart, startPos, active = input.Position, target.Position, false
        BeginDrag(function(i)
            local delta = i.Position - dragStart
            if not active and delta.Magnitude < 5 then return end
            active = true
            target.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end)
    end)
end

local function CreateRowTitle(frame, text)
    local title = Create("TextButton", frame, TITLE_PROPS)
    title.Text, title.Size = text, UDim2.new(0.7, 0, 1, 0)
    Decorate(title, nil, nil, {nil, nil, 15, nil})
    return title
end

function Library:RegisterTab(name, builderFunc) table.insert(self.Tabs, { Name = name, Build = builderFunc }) end

function Library:RegisterLoop(loopType, func, shouldRun, interval)
    local entry = { Func = func, Active = true, ShouldRun = shouldRun, Interval = interval }
    table.insert(self.Loops[loopType], entry)
    return entry
end

function Library:BuildTabs(windowObj) for _, t in ipairs(self.Tabs) do t.Build(windowObj:MakeTab(t.Name), windowObj) end end

