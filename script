            return frame, stroke
        end

        local function WireFocus(box, stroke, frame, cb)
            box.Focused:Connect(function()
                if stroke then Tween(stroke, {Color = Theme.Accent, Transparency = 0.2}) Tween(frame, {BackgroundColor3 = Theme.InputFocus}) else Tween(box, {TextColor3 = Theme.Accent}) end
            end)
            box.FocusLost:Connect(function()
                if stroke then Tween(stroke, {Color = Theme.Stroke, Transparency = 0.7}) Tween(frame, {BackgroundColor3 = Theme.Section}) else Tween(box, {TextColor3 = Theme.Text}) end
                if cb then cb(box.Text) end
            end)
        end

        local function CreateBindButton(parent, props, action)
            if IsMobile then return end
            local bindBtn = Create("TextButton", parent, { Text = props.Keybind, Size = UDim2.new(0, 50, 0.6, 0), Position = UDim2.new(1, -65, 0.2, 0), BackgroundColor3 = Theme.BindBackground, BackgroundTransparency = 0.6, TextColor3 = Theme.SubText, Font = Enum.Font.GothamBold, TextSize = 11 })
            Decorate(bindBtn, UI_CORNER_6, {Theme.Stroke, 0.7, 1})
            local bindId = props.Name .. "_" .. tostring(NextUID())
            KeybindRegistry[bindId] = { Key = props.Keybind, Action = action }
            bindBtn.Destroying:Connect(function()
                KeybindRegistry[bindId] = nil
                PendingBinds[bindId] = nil
            end)
            bindBtn.MouseButton1Click:Connect(function()
                bindBtn.Text = "..."
                Tween(bindBtn, {TextColor3 = Theme.Accent, BackgroundColor3 = Theme.Section})
