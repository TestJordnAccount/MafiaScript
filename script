                if last.dist ~= d then cache.Dist.Text = d .. " studs"; last.dist = d end
            end
        else
            if cache.Chams.Enabled then cache.Chams.Enabled = false end
            if cache.Billboard.Enabled then cache.Billboard.Enabled = false end
        end
    end
end

